    ],
  ];

  // Made it tracking table
  $schema['recipeboxx_recipe_made'] = [
    'description' => 'Tracks "I made this" for recipes',
    'fields' => [
      'recipe_id' => [
        'type' => 'int',
        'not null' => TRUE,
      ],
      'user_id' => [
        'type' => 'int',
        'not null' => TRUE,
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
      ],
    ],
    'unique keys' => [
      'user_recipe_made' => ['user_id', 'recipe_id'],
    ],
    'indexes' => [
      'recipe_id' => ['recipe_id'],
      'user_id' => ['user_id'],
    ],
  ];

  // Shopping lists table
  $schema['recipeboxx_shopping_list'] = [
    'description' => 'Stores shopping lists',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
      ],
      'uuid' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
      ],
      'uid' => [
        'type' => 'int',
        'not null' => TRUE,
        'description' => 'User ID',
      ],
      'name' => [
        'type' => 'varchar',
        'length' => 255,
