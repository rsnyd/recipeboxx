      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
      ],
      'uuid' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
      ],
      'uid' => [
        'type' => 'int',
        'not null' => TRUE,
        'description' => 'User ID',
      ],
      'name' => [
        'type' => 'varchar',
        'length' => 255,
      ],
      'start_date' => [
        'type' => 'int',
        'not null' => TRUE,
      ],
      'status' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => TRUE,
        'default' => 'active',
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
      ],
      'changed' => [
        'type' => 'int',
        'not null' => TRUE,
      ],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'uuid' => ['uuid'],
    ],
    'indexes' => [
      'uid_start_date' => ['uid', 'start_date'],
    ],
  ];

  // Meal plan entries table
  $schema['recipeboxx_meal_plan_entry'] = [
    'description' => 'Stores recipes in meal plans',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
      ],
      'uuid' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
      ],
      'plan_id' => [
        'type' => 'int',
        'not null' => TRUE,
        'description' => 'Meal plan ID',
      ],
      'recipe_id' => [
        'type' => 'int',
        'not null' => TRUE,
        'description' => 'Recipe node ID',
      ],
      'day_of_week' => [
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'description' => '0=Monday, 6=Sunday',
      ],
      'meal_type' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => TRUE,
      ],
      'servings' => [
        'type' => 'int',
