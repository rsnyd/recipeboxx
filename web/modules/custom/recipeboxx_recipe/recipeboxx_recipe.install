    ],
    'primary key' => ['id'],
    'unique keys' => [
      'uuid' => ['uuid'],
    ],
    'indexes' => [
      'plan_id' => ['plan_id'],
      'day_meal' => ['day_of_week', 'meal_type'],
    ],
  ];

  return $schema;
}

/**
 * Add rating and photo fields to recipe content type.
 */
function recipeboxx_recipe_update_9001() {
  $fields = [
    'field_rating_average' => [
      'type' => 'decimal',
      'label' => 'Average Rating',
      'description' => 'Computed average rating from reviews',
      'settings' => [
        'precision' => 3,
        'scale' => 2,
        'min' => 0,
        'max' => 5,
      ],
    ],
    'field_rating_count' => [
      'type' => 'integer',
      'label' => 'Rating Count',
      'description' => 'Number of ratings/reviews',
      'settings' => ['min' => 0],
      'default_value' => [['value' => 0]],
    ],
    'field_made_count' => [
      'type' => 'integer',
      'label' => 'Made Count',
      'description' => 'Number of times users marked "I made this"',
      'settings' => ['min' => 0],
      'default_value' => [['value' => 0]],
    ],
    'field_original_servings' => [
      'type' => 'integer',
      'label' => 'Original Servings',
      'description' => 'Original servings for scaling calculations',
      'settings' => ['min' => 1],
    ],
  ];

  foreach ($fields as $field_name => $config) {
    $field_storage = FieldStorageConfig::loadByName('node', $field_name);
    if (!$field_storage) {
      $storage_config = [
        'field_name' => $field_name,
        'entity_type' => 'node',
        'type' => $config['type'],
        'cardinality' => 1,
      ];

      if (isset($config['settings'])) {
        $storage_config['settings'] = $config['settings'];
      }

      FieldStorageConfig::create($storage_config)->save();
    }

    $field = FieldConfig::loadByName('node', 'recipe', $field_name);
    if (!$field) {
      $field_config = [
        'field_name' => $field_name,
        'entity_type' => 'node',
        'bundle' => 'recipe',
        'label' => $config['label'],
        'description' => $config['description'] ?? '',
      ];

      if (isset($config['default_value'])) {
        $field_config['default_value'] = $config['default_value'];
      }

      FieldConfig::create($field_config)->save();
    }
  }

  // Create image field for recipe photos
  $field_storage = FieldStorageConfig::loadByName('node', 'field_recipe_images');
  if (!$field_storage) {
    FieldStorageConfig::create([
      'field_name' => 'field_recipe_images',
      'entity_type' => 'node',
      'type' => 'image',
      'cardinality' => -1,
      'settings' => [
        'uri_scheme' => 'public',
        'default_image' => [],
      ],
    ])->save();
  }

  $field = FieldConfig::loadByName('node', 'recipe', 'field_recipe_images');
  if (!$field) {
    FieldConfig::create([
      'field_name' => 'field_recipe_images',
      'entity_type' => 'node',
      'bundle' => 'recipe',
      'label' => 'Recipe Photos',
      'description' => 'Upload one or more photos of the recipe',
      'settings' => [
        'file_directory' => 'recipe-photos/[date:custom:Y]-[date:custom:m]',
        'file_extensions' => 'png jpg jpeg gif',
        'max_filesize' => '5 MB',
        'max_resolution' => '2048x2048',
        'min_resolution' => '',
        'alt_field' => TRUE,
        'alt_field_required' => FALSE,
        'title_field' => TRUE,
        'title_field_required' => FALSE,
      ],
    ])->save();
  }

  return t('Added rating, photo, and scaling fields to recipe content type.');
}

/**
 * Add enhanced nutrition fields to recipe content type.
 */
function recipeboxx_recipe_update_9002() {
  $nutrition_fields = [
    'field_saturated_fat' => ['label' => 'Saturated Fat (g)', 'type' => 'decimal'],
    'field_trans_fat' => ['label' => 'Trans Fat (g)', 'type' => 'decimal'],
    'field_cholesterol' => ['label' => 'Cholesterol (mg)', 'type' => 'integer'],
    'field_sodium' => ['label' => 'Sodium (mg)', 'type' => 'integer'],
    'field_sugars' => ['label' => 'Sugars (g)', 'type' => 'integer'],
    'field_vitamin_d' => ['label' => 'Vitamin D (mcg)', 'type' => 'decimal'],
    'field_calcium' => ['label' => 'Calcium (mg)', 'type' => 'integer'],
    'field_iron' => ['label' => 'Iron (mg)', 'type' => 'decimal'],
    'field_potassium' => ['label' => 'Potassium (mg)', 'type' => 'integer'],
  ];

  foreach ($nutrition_fields as $field_name => $config) {
    $field_storage = FieldStorageConfig::loadByName('node', $field_name);
    if (!$field_storage) {
      $storage_config = [
        'field_name' => $field_name,
        'entity_type' => 'node',
        'type' => $config['type'],
        'cardinality' => 1,
      ];

      if ($config['type'] === 'decimal') {
        $storage_config['settings'] = [
          'precision' => 6,
          'scale' => 2,
        ];
      }

      FieldStorageConfig::create($storage_config)->save();
    }

    $field = FieldConfig::loadByName('node', 'recipe', $field_name);
    if (!$field) {
      FieldConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'bundle' => 'recipe',
        'label' => $config['label'],
        'description' => 'Nutrition information per serving',
      ])->save();
    }
  }

  return t('Added enhanced nutrition fields to recipe content type.');
}

/**
 * Implements hook_uninstall().
 */
function recipeboxx_recipe_uninstall() {
  // Remove configuration
  \Drupal::configFactory()->getEditable('recipeboxx_recipe.settings')->delete();

  // Clean up node access table
  \Drupal::database()->delete('node_access')
    ->condition('realm', 'recipeboxx_%', 'LIKE')
    ->execute();
}
