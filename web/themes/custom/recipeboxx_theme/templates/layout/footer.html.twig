{#
/**
 * @file
 * RecipeBoxx theme footer template.
 */
#}
<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="{{ path('<front>') }}" class="logo" rel="home">
          <svg class="logo__icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="48" height="48" rx="12" fill="#d4a744"/>
            <path d="M14 32V20C14 17.7909 15.7909 16 18 16H30C32.2091 16 34 17.7909 34 20V32C34 34.2091 32.2091 36 30 36H18C15.7909 36 14 34.2091 14 32Z" stroke="#1d3a2f" stroke-width="2"/>
            <path d="M18 16V14C18 12.8954 18.8954 12 20 12H28C29.1046 12 30 12.8954 30 14V16" stroke="#1d3a2f" stroke-width="2"/>
            <circle cx="21" cy="24" r="2" fill="#1d3a2f"/>
            <circle cx="27" cy="24" r="2" fill="#1d3a2f"/>
            <path d="M20 29C20 29 22 31 24 31C26 31 28 29 28 29" stroke="#1d3a2f" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="logo__text" style="color: white;">Recipe<span style="color: #d4a744;">Boxx</span></span>
        </a>
        <p class="footer__description">
          {{ 'Your personal recipe collection. Save, organize, and share your favorite recipes with family and friends.'|t }}
        </p>
        <div class="social-links">
          <a href="#" class="social-link" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Pinterest">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.627 0-12 5.372-12 12 0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
            </svg>
          </a>
        </div>
      </div>

      {% if page.footer_first %}
        <div class="footer__column">
          {{ page.footer_first }}
        </div>
      {% else %}
        <div class="footer__column">
          <h4 class="footer__title">{{ 'Quick Links'|t }}</h4>
          <ul class="footer__links">
            <li><a href="{{ path('<front>') }}" class="footer__link">{{ 'Home'|t }}</a></li>
            <li><a href="#" class="footer__link">{{ 'Browse Recipes'|t }}</a></li>
            <li><a href="#" class="footer__link">{{ 'Categories'|t }}</a></li>
            <li><a href="#" class="footer__link">{{ 'Collections'|t }}</a></li>
          </ul>
        </div>
      {% endif %}

      {% if page.footer_second %}
        <div class="footer__column">
          {{ page.footer_second }}
        </div>
      {% else %}
        <div class="footer__column">
          <h4 class="footer__title">{{ 'Categories'|t }}</h4>
          <ul class="footer__links">
            <li><a href="#" class="footer__link">{{ 'Breakfast'|t }}</a></li>
            <li><a href="#" class="footer__link">{{ 'Lunch'|t }}</a></li>
            <li><a href="#" class="footer__link">{{ 'Dinner'|t }}</a></li>
            <li><a href="#" class="footer__link">{{ 'Desserts'|t }}</a></li>
          </ul>
        </div>
      {% endif %}

      {% if page.footer_third %}
        <div class="footer__column">
          {{ page.footer_third }}
        </div>
      {% else %}
        <div class="footer__column">
          <h4 class="footer__title">{{ 'Support'|t }}</h4>
          <ul class="footer__links">
            <li><a href="/help-center" class="footer__link">{{ 'Help Center'|t }}</a></li>
            <li><a href="/contact" class="footer__link">{{ 'Contact Us'|t }}</a></li>
            <li><a href="/privacy-policy" class="footer__link">{{ 'Privacy Policy'|t }}</a></li>
            <li><a href="/terms-of-service" class="footer__link">{{ 'Terms of Service'|t }}</a></li>
          </ul>
        </div>
      {% endif %}
    </div>

    <div class="footer__bottom">
      <p class="copyright">
        &copy; {{ 'now'|date('Y') }} {{ 'RecipeBoxx. All rights reserved.'|t }}
      </p>
      {% if page.footer %}
        {{ page.footer }}
      {% endif %}
    </div>
  </div>
</footer>
