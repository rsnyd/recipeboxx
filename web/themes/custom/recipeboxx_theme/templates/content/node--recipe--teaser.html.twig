{#
/**
 * @file
 * RecipeBoxx theme implementation for Recipe teaser (card) display.
 */
#}
{%
  set classes = [
    'recipe-card',
    'node',
    'node--type-' ~ node.bundle|clean_class,
    node.isPromoted() ? 'node--promoted',
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  ]
%}

<article{{ attributes.addClass(classes) }}>
  <a href="{{ url }}" class="recipe-card__link" aria-labelledby="recipe-title-{{ node.id }}">
    <div class="recipe-card__image">
      {% if content.field_recipe_images|render|trim %}
        {{ content.field_recipe_images }}
      {% else %}
        {# Placeholder image #}
        <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=400&h=300&fit=crop" alt="{{ label }}" loading="lazy">
      {% endif %}

      {% if content.field_total_time|render|trim %}
        <span class="recipe-card__time">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          {{ content.field_total_time }} {{ 'min'|t }}
        </span>
      {% endif %}

      {% if content.field_meal_type|render|trim %}
        <span class="card__badge">
          {{ content.field_meal_type }}
        </span>
      {% endif %}
    </div>
  </a>

  <div class="recipe-card__content">
    {% if content.field_cuisine_type|render|trim %}
      <span class="card__category">{{ content.field_cuisine_type }}</span>
    {% endif %}

    <h3 class="recipe-card__title" id="recipe-title-{{ node.id }}">
      <a href="{{ url }}">{{ label }}</a>
    </h3>

    {% if content.body|render|trim %}
      <p class="recipe-card__description">
        {{ content.body|render|striptags|trim|slice(0, 120) }}{% if content.body|render|striptags|trim|length > 120 %}...{% endif %}
      </p>
    {% endif %}

    <div class="recipe-card__footer">
      <div class="recipe-card__stats">
        {% if content.field_servings|render|trim %}
          <span class="recipe-card__stat">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
            </svg>
            {{ content.field_servings }} {{ 'servings'|t }}
          </span>
        {% endif %}

        {% if content.field_calories|render|trim %}
          <span class="recipe-card__stat">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
            </svg>
            {{ content.field_calories }} {{ 'cal'|t }}
          </span>
        {% endif %}
      </div>

      {% if content.field_rating_average|render|trim %}
        <div class="recipe-card__rating">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
          </svg>
          {{ content.field_rating_average }}
        </div>
      {% endif %}
    </div>
  </div>
</article>
